{
  "name": "trustpay-stellar-mvp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm --prefix frontend run dev --",
    "prebuild": "npm --prefix frontend install --include=dev",
    "build": "npm --prefix frontend run build",
    "lint": "npm --prefix frontend run lint",
    "preview": "npm --prefix frontend run preview",
    "contract:check": "cargo check --manifest-path contract/trustpay-escrow/Cargo.toml",
    "contract:build": "cargo build --manifest-path contract/trustpay-escrow/Cargo.toml --target wasm32-unknown-unknown --release",
    "contract:test": "cargo test --manifest-path contract/trustpay-escrow/Cargo.toml",
    "test": "npm run contract:test && npm --prefix frontend run test"
  }
}
